From dbe11c1e2d6c5700d080f46d219aab8ce982276d Mon Sep 17 00:00:00 2001
From: Rui Chung <rui_zhong@arcadyan.com>
Date: Tue, 29 Apr 2025 16:11:42 +0800
Subject: [PATCH] [pwhm][Do not disable 80211be when MLO is disabled]

[Description]
Do not disable 80211be when MLO is disabled, it is unreasonable.

[ChangeLog]
N/A
---
 src/nl80211/wld_hostapd_cfgFile.c | 3 ---
 1 file changed, 3 deletions(-)

diff --git a/src/nl80211/wld_hostapd_cfgFile.c b/src/nl80211/wld_hostapd_cfgFile.c
index ec33e73..49f4bc5 100644
--- a/src/nl80211/wld_hostapd_cfgFile.c
+++ b/src/nl80211/wld_hostapd_cfgFile.c
@@ -802,9 +802,6 @@ static bool s_setVapCommonConfig(T_AccessPoint* pAP, swl_mapChar_t* vapConfigMap
              * 0 = no (no MLO)
              * 1 = yes (MLO) */
             swl_mapCharFmt_addValInt32(vapConfigMap, "mld_ap", 1);
-        } else {
-            /* if no MLO, then no 11BE */
-            swl_mapCharFmt_addValInt32(vapConfigMap, "disable_11be", 1);
         }
     }
 
