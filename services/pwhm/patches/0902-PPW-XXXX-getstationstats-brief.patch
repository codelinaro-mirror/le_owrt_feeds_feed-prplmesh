+/**
+ * PPW-XXXX: lean reply builder for the getStationStatsBrief() RPC.
+ *
+ * Unlike s_addStaStatsValues(), which re-marshals the whole AssociatedDevice
+ * datamodel object (plus its AffiliatedSta sub-list) back out via
+ * swla_dm_getObjectParams() for every station on every poll, this emits only
+ * the small fixed set of volatile fields that the sole consumer -- the prplMesh
+ * monitor (mon_wlan_hal_whm.cpp read_station_stats) -- actually parses, built
+ * directly from the live T_AssociatedDevice. The shared prologue still runs
+ * wld_vap_sync_assoclist() (hence wld_ad_syncStats()), so pAD == DM at reply
+ * time and these values match what a full readback would return.
+ *
+ * The value expressions, types and the alias quirks (TxErrors<-TxFailures,
+ * RxErrors<-RxFailures emitted as uint64) are copied VERBATIM from
+ * s_setAssocDevStatsParams() -- keep the two in sync. This 14-key set is a tight
+ * cross-repo contract with the prplMesh monitor: adding a field is a conscious
+ * two-repo change (see the prplmesh 0002 patch header).
+ */
+static void s_addStaStatsValuesBrief(T_AccessPoint* pAP, swl_rc_ne ret, amxc_var_t* retval) {
+    s_addStaStatsPrologue(pAP, ret, retval);
+
+    for(int i = 0; i < pAP->AssociatedDeviceNumberOfEntries; i++) {
+        T_AssociatedDevice* pAD = pAP->AssociatedDevice[i];
+        if((pAD == NULL) || (pAD->object == NULL)) {
+            SAH_TRACEZ_ERROR(ME, "%s: invalid sta %u", pAP->alias, i);
+            continue;
+        }
+
+        amxc_var_t tmpVar;
+        amxc_var_init(&tmpVar);
+        amxc_var_set_type(&tmpVar, AMXC_VAR_ID_HTABLE);
+
+        swl_macChar_t mac;
+        swl_mac_binToChar(&mac, (swl_macBin_t*) pAD->MACAddress);
+        amxc_var_add_new_key_cstring_t(&tmpVar, "MACAddress", mac.cMac);
+
+        amxc_var_add_new_key_uint64_t(&tmpVar, "TxBytes", pAD->TxBytes);
+        amxc_var_add_new_key_uint64_t(&tmpVar, "RxBytes", pAD->RxBytes);
+        amxc_var_add_new_key_uint32_t(&tmpVar, "TxErrors", pAD->TxFailures);
+        amxc_var_add_new_key_uint64_t(&tmpVar, "RxErrors", pAD->RxFailures);
+        amxc_var_add_new_key_uint32_t(&tmpVar, "TxPacketCount", pAD->TxPacketCount);
+        amxc_var_add_new_key_uint32_t(&tmpVar, "RxPacketCount", pAD->RxPacketCount);
+        amxc_var_add_new_key_uint32_t(&tmpVar, "TxUnicastPacketCount", pAD->TxUnicastPacketCount);
+        amxc_var_add_new_key_uint32_t(&tmpVar, "Tx_Retransmissions", pAD->Tx_Retransmissions);
+        amxc_var_add_new_key_uint32_t(&tmpVar, "LastDataDownlinkRate", pAD->LastDataDownlinkRate);
+        amxc_var_add_new_key_uint32_t(&tmpVar, "LastDataUplinkRate", pAD->LastDataUplinkRate);
+        amxc_var_add_new_key_uint32_t(&tmpVar, "DownlinkBandwidth", pAD->DownlinkBandwidth);
+        amxc_var_add_new_key_int32_t(&tmpVar, "SignalNoiseRatio", pAD->SignalNoiseRatio);
+        amxc_var_add_new_key_int32_t(&tmpVar, "SignalStrength", pAD->SignalStrength);
+
+        amxc_var_add_new_amxc_htable_t(retval, &tmpVar.data.vm);
+
+        amxc_var_clean(&tmpVar);
+    }
+}
