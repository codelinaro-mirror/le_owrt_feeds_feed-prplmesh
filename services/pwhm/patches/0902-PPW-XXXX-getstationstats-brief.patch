     amxd_function_deferred_done(pAP->stationsStatsState.call_id,
                                 success ? amxd_status_ok : amxd_status_unknown_error,
@@ -1019,6 +1094,10 @@
         return amxd_status_unknown_error;
     }
 
+    /* PPW-XXXX: full reply on this path; clear the selector that the (possibly
+     * deferred) completion handler s_staStatsDoneHandler() reads. */
+    pAP->stationsStatsBriefReply = false;
+
     swl_rc_ne ret = pAP->pFA->mfn_wvap_get_station_stats(pAP);
     SAH_TRACEZ_INFO(ME, "%s: sta stats %i", pAP->alias, ret);
     if(ret == SWL_RC_CONTINUE) {
@@ -1038,6 +1117,62 @@
 
     SAH_TRACEZ_OUT(ME);
     return amxd_status_ok;
+}
+
+/**
+ * PPW-XXXX: getStationStatsBrief() RPC handler.
+ *
+ * Identical control flow to _getStationStats() above (synchronous + deferred
+ * driver-pull paths), but flags the call so the reply is built by the lean
+ * s_addStaStatsValuesBrief() instead of the full s_addStaStatsValues(). The
+ * datamodel is still fully synced (the shared prologue runs
+ * wld_vap_sync_assoclist()), so TR-181 AssociatedDevice.* consumers are
+ * unaffected; only the RPC reply payload is trimmed to the monitor's contract.
+ */
+amxd_status_t _getStationStatsBrief(amxd_object_t* obj_AP,
+                                    amxd_function_t* func _UNUSED,
+                                    amxc_var_t* args _UNUSED,
+                                    amxc_var_t* retval) {
+
+    SAH_TRACEZ_IN(ME);
+    /* Check our input data */
+    T_AccessPoint* pAP = obj_AP->priv;
+
+    if(!debugIsVapPointer(pAP)) {
+        SAH_TRACEZ_OUT(ME);
+        return amxd_status_unknown_error;
+    }
+
+    SAH_TRACEZ_INFO(ME, "pAP = %p", pAP);
+
+    if(pAP->stationsStatsState.running) {
+        SAH_TRACEZ_ERROR(ME, "%s: getStationStats is already running", pAP->alias);
+        SAH_TRACEZ_OUT(ME);
+        return amxd_status_unknown_error;
+    }
+
+    /* PPW-XXXX: lean reply on this path; the completion handler reads it. */
+    pAP->stationsStatsBriefReply = true;
+
+    swl_rc_ne ret = pAP->pFA->mfn_wvap_get_station_stats(pAP);
+    SAH_TRACEZ_INFO(ME, "%s: sta stats %i", pAP->alias, ret);
+    if(ret == SWL_RC_CONTINUE) {
+        pAP->stationsStatsState.running = true;
+        amxp_timer_t* timer = NULL;
+        amxp_timer_new(&timer, s_staStatsTimeout, pAP);
+        amxp_timer_start(timer, STATIONS_STATS_TIMEOUT);
+
+        pAP->stationsStatsState.timer = timer;
+
+        amxd_function_defer(func, &pAP->stationsStatsState.call_id, retval, s_staStatsCancel, pAP);
+        SAH_TRACEZ_OUT(ME);
+        return amxd_status_deferred;
+    }
+
+    s_addStaStatsValuesBrief(pAP, ret, retval);
+
+    SAH_TRACEZ_OUT(ME);
+    return amxd_status_ok;
 }
 
