+swl_rc_ne wld_util_setObjStatsParams(amxd_object_t* object, void* userData, wld_dm_objStatsParamHdlr_f paramHdlr) {
+    ASSERT_NOT_NULL(object, SWL_RC_INVALID_PARAM, ME, "NULL");
+    ASSERT_NOT_NULL(paramHdlr, SWL_RC_INVALID_PARAM, ME, "Missing handler");
+
+    amxd_param_t* param = NULL;
+    const char* paramName = NULL;
+    amxc_var_t value;
+    swl_rc_ne hdlRc = SWL_RC_ERROR;
+
+    amxd_object_for_each(parameter, it, object) {
+        param = amxc_llist_it_get_data(it, amxd_param_t, it);
+        paramName = amxd_param_get_name(param);
+        amxc_var_init(&value);
+        hdlRc = paramHdlr(param, paramName, &value, userData);
+        if((hdlRc == SWL_RC_OK) && (value.type_id != AMXC_VAR_ID_NULL)) {
+            amxd_status_t status = amxd_action_param_write(object, param, action_param_write, &value, NULL, NULL);
+            if(status != amxd_status_ok) {
+                SAH_TRACEZ_WARNING(ME, "fail to saved typed value to station stats param (%s) (status:%s)",
+                                   paramName, amxd_status_string(status));
+            }
+        } else if(hdlRc < SWL_RC_OK) {
+            SAH_TRACEZ_WARNING(ME, "fail to set typed value of (%s)", paramName);
+        }
+        amxc_var_clean(&value);
+    }
+
+    return SWL_RC_OK;
+}
