+/**
+ * @brief local handler to fill affiliated AP stats param values
+ */
+static swl_rc_ne s_setAffAPStatsParams(amxd_param_t* param, const char* paramName, amxc_var_t* newVal, void* userData) {
+    ASSERTS_NOT_NULL(param, SWL_RC_INVALID_PARAM, ME, "NULL param");
+    ASSERTS_NOT_NULL(newVal, SWL_RC_INVALID_PARAM, ME, "NULL value");
+    wld_mloStats_t* stats = (wld_mloStats_t*) userData;
+    ASSERTS_NOT_NULL(stats, SWL_RC_INVALID_PARAM, ME, "NULL context");
+    ASSERTS_STR(paramName, SWL_RC_INVALID_PARAM, ME, "empty name");
+
+    int ret = -1;
+    if(swl_str_matches(paramName, "PacketsSent")) {
+        ret = amxc_var_set_uint32_t(newVal, stats->txPackets);
+    } else if(swl_str_matches(paramName, "PacketsReceived")) {
+        ret = amxc_var_set_uint32_t(newVal, stats->rxPackets);
+    } else if(swl_str_matches(paramName, "UnicastBytesSent")) {
+        ret = amxc_var_set_uint32_t(newVal, stats->txUbyte);
+    } else if(swl_str_matches(paramName, "UnicastBytesReceived")) {
+        ret = amxc_var_set_uint32_t(newVal, stats->rxUbyte);
+    } else if(swl_str_matches(paramName, "ErrorsSent")) {
+        ret = amxc_var_set_uint32_t(newVal, stats->txEbyte);
+    } else if(swl_str_matches(paramName, "MulticastBytesSent")) {
+        ret = amxc_var_set_uint32_t(newVal, stats->txMbyte);
+    } else if(swl_str_matches(paramName, "MulticastBytesReceived")) {
+        ret = amxc_var_set_uint32_t(newVal, stats->rxMbyte);
+    } else if(swl_str_matches(paramName, "BroadcastBytesSent")) {
+        ret = amxc_var_set_uint32_t(newVal, stats->txBbyte);
+    } else if(swl_str_matches(paramName, "BroadcastBytesReceived")) {
+        ret = amxc_var_set_uint32_t(newVal, stats->rxBbyte);
+    } else {
+        return SWL_RC_CONTINUE;
+    }
+    if(ret < 0) {
+        return SWL_RC_ERROR;
+    }
+    return SWL_RC_OK;
+}
