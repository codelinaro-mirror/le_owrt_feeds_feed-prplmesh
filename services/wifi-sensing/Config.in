config PACKAGE_wifi-sensing
    tristate
    select SAH_SERVICES_SENSING

if PACKAGE_wifi-sensing

menu "Select wifi-sensing build options"
    depends on PACKAGE_wifi-sensing

config SAH_SERVICES_SENSING
    bool "Build wifi sensing itself"
    default y

config SAH_SERVICES_SENSING_START_ORDER
    int "Start up order"
    default 98

config SAH_SERVICES_SENSING_STOP_ORDER
    int "Stop order"
    default 1

config SAH_SERVICES_SENSING_PROCESS_MANAGER
    bool "Disable autostart in WiFi-Sensing when Process Manager enabled"
    default y
    depends on PACKAGE_prplmesh-process-manager

config SAH_SERVICES_SENSING_AMX_PROCESSMONITOR
    bool "Install AMX ProcessMonitor files when component enabled"
    default y
    depends on (SAH_AMX_PROCESSMONITOR || PACKAGE_amx-processmonitor)

config SAH_SERVICES_SENSING_DATAMODEL_MAPPER
    bool "Enable prplMesh DataModel Mapper connection"
    default y
    depends on PACKAGE_prplmesh-dm-mapper

endmenu

endif
