#!/bin/sh /etc/rc.common

. "${IPKG_INSTROOT}/usr/lib/amx/scripts/amx_procd_init_functions.sh"

START=99
USE_PROCD=1

name="prplmesh"
datamodel_root="Device.WiFi.DataElements."

PROCESS_MANAGER_DM="X_PRPLWARE-COM_ProcessManager.PrplMesh"
PRPLMESH_DIR="${IPKG_INSTROOT}/opt/prplmesh"
ODL_FILES="
${PRPLMESH_DIR}/share/agent/odl/agent.odl
${PRPLMESH_DIR}/config/agent/odl/defaults.d/00_slave_configuration.odl
"

pwhm_ready() {
    ba-cli Device.WiFi.Radio.?0 | grep -q "ERROR: .* not found" && return 1 || return 0
}

pwhm_ready_poll() {
    local delay=${1-3}
    local timeout=150

    start_time="$(date -u +%s)"
    while true ; do
        if pwhm_ready; then
            break
        fi

        end_time="$(date -u +%s)"
        elapsed="$(($end_time-$start_time))"
        if [ "$elapsed" -gt "$timeout" ]; then
            return 1
        fi

        sleep $delay
    done
}

odl_get_str_param() {
    key=$1
    default=$2
    value=""

    for file in $ODL_FILES; do
        [ -e "${file}" ] || continue
        value=$(sed -n -E "s/^[[:space:]]*parameter[[:space:]]*['\"]?${key}['\"]?[[:space:]]*=[[:space:]]*\"([^\"]*)\".*/\1/p" "${file}")
        [ -n "${value}" ] && break
    done

    [ -z "${value}" ] && value=$default

    echo "${value}"
}

odl_set_param() {
    name=$1
    value=$2
    type=$3

    for file in $ODL_FILES; do
        [ -e "${file}" ] || continue

        case "${type}" in
            string)
                sed -i "s/\(parameter[[:space:]]\+${name}[[:space:]]*=[[:space:]]*\"\)[^\"]*\";/\1${value}\";/" "${file}"
                sed -i "s/\(parameter[[:space:]]\+'${name}'[[:space:]]*=[[:space:]]*\"\)[^\"]*\";/\1${value}\";/" "${file}"
                ;;
            bool)
                sed -i "s/\(parameter[[:space:]]\+${name}[[:space:]]*=[[:space:]]*\)[^;]*;/\1${value};/" "${file}"
                sed -i "s/\(parameter[[:space:]]\+'${name}'[[:space:]]*=[[:space:]]*\)[^;]*;/\1${value};/" "${file}"
                ;;
            *)
                echo "Unsupported param_type: ${type}" >&2
                return 1
                ;;
        esac
    done

    return 0
}

get_management_mode() {
    mode=$(
            ba-cli -l "${PROCESS_MANAGER_DM}.ManagementMode?" 2>&1 \
            | grep -v '^ERROR:' \
            | tr -d '\n'
        )

    # Fallback to prplMesh configuration DM or to Multi-AP-Controller-and-Agent as default
    [ -z "${mode}" ] && mode=$(odl_get_str_param "ManagementMode" "Multi-AP-Controller-and-Agent")

    echo "${mode}"
}

set_management_and_certification_mode() {
    management_mode=$1
    certification_mode=$2

    if [ -n "${management_mode}" ]; then
        case "${management_mode}" in
            Not-Multi-AP|Multi-AP-Agent|Multi-AP-Controller|Multi-AP-Controller-and-Agent|Non-Prpl-Controller-and-Agent)
                ;;
            *)
                echo "unsupported mode: \"${management_mode}\""
                return 1
                ;;
        esac

        echo "Set prplMesh management_mode to ${management_mode}"
        odl_set_param "ManagementMode" "${management_mode}" "string" || return 1
    fi

    if [ -n "${certification_mode}" ]; then
        echo "Set prplMesh certification_mode to ${certification_mode}"
        odl_set_param "CertificationMode" "${certification_mode}" "bool" || return 1
    fi

    return 0
}

setmode() {
    forced_mode=""
    forced_cert=""

    while [ $# -gt 0 ]; do
        case "$1" in
            --mode|-m)
                [ -n "${2}" ] || { echo "--mode requires a value" >&2; return 1; }
                forced_mode="${2}"; shift 2 ;;
            --cert|-c)
                [ -n "${2}" ] || { echo "--cert requires a value" >&2; return 1; }
                forced_cert="${2}"; shift 2 ;;
            --) shift; break ;;
            *)  echo "Unknown arg: ${1}" >&2; return 1 ;;
        esac
    done

    [ -n "${forced_mode}" ] || [ -n "${forced_cert}" ] || {
        echo "Nothing to set (pass --mode and/or --cert)" >&2
        return 1
    }

    stop || return 1

    # Avoid a shutdown race: beerocks_agent may rewrite ODL files while exiting.
    # Wait for it to terminate before updating ManagementMode/CertificationMode.
    for i in $(seq 1 50); do
        pgrep -f beerocks_agent >/dev/null || break
        sleep 0.1
    done
    pgrep -f beerocks_agent >/dev/null && { echo "agent still running" >&2; return 1; }

    set_management_and_certification_mode "${forced_mode}" "${forced_cert}" || return 1

    start || return 1
}

start_service() {
    if ! pwhm_ready_poll; then
        echo "pwhm not ready - aborting prplmesh start" >&2
        return 1
    fi

    # This is required for solveing issue which causing meesges not geeting to their destination.
    # For more information see: https://github.com/prplfoundation/prplMesh/pull/1029#issuecomment-608353274
    ebtables -A FORWARD -d 01:80:c2:00:00:13 -j DROP

    mode="$(get_management_mode)"

    register_service "prplmesh_transport" "${PRPLMESH_DIR}/bin/ieee1905_transport"
    # If mode isn't Multi-AP-Agent then it Multi-AP-Controller 
    # or Multi-AP-Controller-and-Agent so we need to register 
    # controller process as well
    if [ "${mode}" != "Multi-AP-Agent" ] && [ "${mode}" != "Non-Prpl-Controller-and-Agent" ]; then
        register_service "prplmesh_controller" "${PRPLMESH_DIR}/bin/beerocks_controller"
    fi
    register_service "prplmesh_agent" "${PRPLMESH_DIR}/bin/beerocks_agent"
    register_service "prplmesh_vendor_message" "${PRPLMESH_DIR}/bin/beerocks_vendor_message"

    return 0
}

stop_service() {
    deregister_service "prplmesh_vendor_message"
    deregister_service "prplmesh_agent"
    deregister_service "prplmesh_controller"
    deregister_service "prplmesh_transport"

    ebtables -D FORWARD -d 01:80:c2:00:00:13 -j DROP
    return 0
}

extra_command "setmode" "Set ManagementMode/CertificationMode and restart prplmesh"