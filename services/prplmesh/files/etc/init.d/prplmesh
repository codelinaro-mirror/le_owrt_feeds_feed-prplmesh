#!/bin/sh /etc/rc.common

START=99
NAME=prplmesh

AGENT_DM_CACHE_FILE_PATH=/opt/prplmesh/share/agent/odl/agent.odl
AGENT_DM_DEFAULTS_FILE_PATH=/opt/prplmesh/config/agent/odl/defaults.d/00_slave_configuration.odl

##############################
# Log function - log_msg
# Usage: log_msg "message"
##############################
log_msg() {
    # Logs to syslog and echoes to stdout
    local saved_exit_code=$?  
    logger -t "${NAME}" "$1"
    echo "$1"
    return $saved_exit_code  
}

###########################################
# 1. Helper functions - Wi-Fi Operations
###########################################

__wlan_reset__() {
    wifi down
    sleep 5
    local leftover_processes="$(ps | grep '[h]ostapd\|[s]upp')"
    if [ -n "$leftover_processes" ]; then
        log_msg "Wlan processes still running after wifi down: $leftover_processes"
        # STA interfaces/processes sometimes not closed properly (https://jira.prplfoundation.org/browse/PPM-1778)
        # This issue was spotted after wifi driver release update UGW8.5.2 in prplos.
        # Currently just log this event and continue.
        # In case wlan will not recover wlan_ready() will handle it.
    fi
    wifi up
}

# Function __dm_obj_exists__ <obj_path>
#
# returns true if obj is found in ba-cli
# returns false if otherwise
#
# usage __dm_obj_exists__ "Device.WiFi.Radio"
__dm_obj_exists__() {
    local obj_path=$1
    ba-cli "${obj_path}.?0" | grep -Eq "No data found|ERROR" &>/dev/null && return 1
    return 0
}

__check_wlan_available__() {
    # This check is kept like it was without any changes. It is very specific and works like this:
    # 1. hostapd_cli - checks if hostapd daemon responsible for managing AP 
    #        on $1 iface is running at the moment 
    #        (usually it fails if no WiFi.AccessPoint.*.Enable=1 are set)
    # 2. ba-cli - checks for 'Radio.?0', but actually it ALWAYS return 0 exit code. 
    #        But more interesting is that under the hood it has 'wait' for pWHM ready, 
    #        so it helps us to start prplmesh in time without breaking the boot sequence 
    # 3. So, if hostapd is not running, we do the check for Radio object, that just waits
    #        for pWHM ready and start prplmesh, saying that "WLAN is ready", tho it's not
    hostapd_cli -i$1 stat &>/dev/null || ba-cli Device.WiFi.Radio.?0 &> /dev/null
}

__get_radio_names__() {
    ba-cli -l "WiFi.Radio.*.Name?"
}

__all_wlan_ready__() {
    for iface in "$(__get_radio_names__)"; do
        if ! __check_wlan_available__ "$iface"; then
            log_msg "$0: $iface not ready"
            log_msg "TEMP: $iface not ready"
            return 1
        fi
    done
    return 0
}

__wait_for_all_wlan_ready__() {
    local delay=${1-3}
    local timeout=60

    start_time="$(date -u +%s)"
    while true; do
        if __all_wlan_ready__; then
            break
        fi

        end_time="$(date -u +%s)"
        elapsed="$(($end_time - $start_time))"
        if [ "$elapsed" -gt "$timeout" ]; then
            return 1
        fi

        sleep $delay
    done
    return 0
}

###############################################
# 2. Configuration Service functions
###############################################

__get_management_mode__() {
    local management_mode

    if  __dm_obj_exists__ "X_PRPLWARE-COM_Agent.Configuration"; then
        management_mode="$(ba-cli X_PRPLWARE-COM_Agent.Configuration.ManagementMode? 2>/dev/null | awk -F'= ' '/ManagementMode/ {gsub(/[";]/,"",$2); print $2}')"
    elif [ -f "${AGENT_DM_CACHE_FILE_PATH}" ]; then
        # Read from cache ODL file
        management_mode="$(awk -F'= ' '/parameter .ManagementMode./ {gsub(/[";]/,"",$2); print $2}' "$AGENT_DM_CACHE_FILE_PATH")"
    else
        # Read from defaults ODL file
        management_mode="$(awk -F'= ' '/parameter .ManagementMode./ {gsub(/[";]/,"",$2); print $2}' "$AGENT_DM_DEFAULTS_FILE_PATH")"
    fi

    echo "$management_mode"
}

# Function: __sed_config_option_in_odl__ key value file
#
# Updates or inserts a configuration parameter in an ODL file.
#
# - If the parameter 'key' exists in the specified 'file',
#   its value is updated to 'value'.
# - If the parameter does not exist, a new parameter line is
#   inserted into the 'object Configuration' section of the file.
#
# Usage: __sed_config_option_in_odl__ <key> <value> <file>
__sed_config_option_in_odl__() {
    local key="$1"
    local value="$2"
    local file="$3"
    local param_line="parameter '${key}' = \"${value}\";"

    # Check if the parameter exists
    if grep -q "parameter '${key}'" "$file"; then
        # Update the existing parameter value
        sed -i "s|^\([[:space:]]*parameter '${key}' = \).*;|\1\"${value}\";|" "$file"
    else
        # Insert new parameter inside object 'Configuration' { ... }
        log_msg "Option $key was not present in ODL, inserting one"
        sed -i "/object 'Configuration' {/,/^ *}/{/^ *}/i\\$param_line }" "$file"
    fi
}

# Function: __update_config_option__
#
# Updates configuration option in Agent DM
#
# Usage: __update_config_option__ <key> <value>
__update_config_option__() {
    local key="$1"
    local value="$2"

    if __dm_obj_exists__ "X_PRPLWARE-COM_Agent.Configuration"; then
        log_msg "Agent is running: update value of '$key' to '$value' in DM"
        ba-cli "X_PRPLWARE-COM_Agent.Configuration.$key=$value"
    elif [ -f "${AGENT_DM_CACHE_FILE_PATH}" ]; then
        log_msg "Cache file exists: update value of '$key' to '$value'"
        __sed_config_option_in_odl__ $key $value $AGENT_DM_CACHE_FILE_PATH
    else
        log_msg "First run of prplmesh: update value of '$key' to '$value' in defaults.d"
        __sed_config_option_in_odl__ $key $value $AGENT_DM_DEFAULTS_FILE_PATH
    fi
}

__set_repeater_mode__() {
    __update_config_option__ "ManagementMode" "Agent"
}

__set_gateway_mode__() {
    __update_config_option__ "ManagementMode" "Controller+Agent"
}

__set_certification_mode__() {
    __update_config_option__ "CertificationMode" "1"
}

#############################
# 3. Main Service Operations
#############################

__start__() {
    log_msg "Start prplMesh"

    # Waiting for all WLAN ifaces to become ready
    __wait_for_all_wlan_ready__ || {
        log_msg "Timeout waiting for WLAN ready!"
        exit 1
    }

    # Read ManagementMode from DM, cache, or defaults
    local management_mode
    management_mode="$(__get_management_mode__)"
    log_msg "ManagementMode: ${management_mode}"

    case "$management_mode" in
    "Controller+Agent")
        log_msg "Start prplMesh controller & agent"
        /opt/prplmesh/scripts/prplmesh_utils.sh start -m CA
        ;;
    "Agent")
        log_msg "Start prplMesh agent"
        /opt/prplmesh/scripts/prplmesh_utils.sh start -m A
        ;;
    *)
        log_msg "Unknown ManagementMode: ${management_mode}, just doing start"
        /opt/prplmesh/scripts/prplmesh_utils.sh start
        ;;
    esac
}

__stop__() {
    log_msg "Stop prplMesh"

    /opt/prplmesh/scripts/prplmesh_utils.sh stop

    # since prplmesh changes the wifi runtime configuration,
    # restart wifi when stopping prplmesh
    # unless using prplmesh wireless hardware manager
    ba-cli Device.WiFi.Radio.?0 &>/dev/null || __wlan_reset__
}

__restart__() {
    log_msg "Restart prplMesh"

    # prplmesh_utils do the same for 'restart' option (restart = stop & start),
    # but does not wait for wlan ifaces to become ready,
    # so it's needed to do this manually
    __stop__
    __start__
}

__status__() {
    # Show if radios are enabled
    for radio_name in $(__get_radio_names__); do
        enabled=$(ba-cli -l "WiFi.Radio.[Name == \"$radio_name\"].Enable?")
        if [ "$enabled" -eq 1 ]; then
            echo "$radio_name is enabled"
        else
            echo "$radio_name is disabled"
        fi
    done

    # prplMesh configuration status
    __all_wlan_ready__ && echo "WLAN Ready" || echo "WLAN not ready"
    /opt/prplmesh/scripts/prplmesh_utils.sh status
}

__repeater_mode__() {
    __set_repeater_mode__
    __restart__
    log_msg "prplmesh repeater mode set"
}

__gateway_mode__() {
    __set_gateway_mode__
    __restart__
    log_msg "prplmesh gateway mode set"
}

__certification_mode__() {
    mode=${1-gateway} # gateway by default

    case "$mode" in
    controller | gateway | controller_mode | gateway_mode)
        __uci_set_gateway_mode__
        __uci_set_certification_mode__
        ;;
    agent | repeater | agent_mode | repeater_mode)
        __uci_set_repeater_mode__
        __uci_set_certification_mode__
        ;;
    esac
    __restart__
}

##################
# 3. Entry Points
##################

start() { __start__; }
stop() { __stop__; }
restart() { __restart__; }
status() { __status__; }
repeater_mode() { __repeater_mode__; }
gateway_mode() { __gateway_mode__; }
certification_mode() { __certification_mode__; }

#############################
# 4. Extra Commands and Help
##############################

EXTRA_COMMANDS="status repeater_mode gateway_mode certification_mode"
EXTRA_HELP='''
	status                    show service status
	certification_mode <mode> set certification controller mode
	repeater_mode [backhaul]  set repeater mode with backhaul wired (default) or wireless
	gateway_mode              set gateway mode
'''

