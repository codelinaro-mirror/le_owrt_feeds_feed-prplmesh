#!/bin/sh /etc/rc.common

. "${IPKG_INSTROOT}/usr/lib/amx/scripts/amx_procd_init_functions.sh"

START=99
USE_PROCD=1

name="prplmesh"
datamodel_root="Device.WiFi.DataElements."

PROCESS_MANAGER_DM="X_PRPLWARE-COM_ProcessManager.PrplMesh"
PRPLMESH_DIR="${IPKG_INSTROOT}/opt/prplmesh"
ODL_FILES="
${PRPLMESH_DIR}/share/agent/odl/agent.odl
${PRPLMESH_DIR}/config/agent/odl/defaults.d/00_slave_configuration.odl
"

pwhm_ready() {
    ba-cli Device.WiFi.Radio.?0 | grep -q "ERROR: .* not found" && return 1 || return 0
}

pwhm_ready_poll() {
    local delay=${1-3}
    local timeout=150

    start_time=$(cut -d. -f1 /proc/uptime)
    while true ; do
        if pwhm_ready; then
            break
        fi

        end_time=$(cut -d. -f1 /proc/uptime)
        elapsed=$(($end_time - $start_time))
        if [ "$elapsed" -gt "$timeout" ]; then
            return 1
        fi

        sleep $delay
    done
}

odl_get_str_param() {
    key=$1
    value=""

    for file in $ODL_FILES; do
        [ -e "${file}" ] || continue
        value=$(sed -n -E "s/^[[:space:]]*parameter[[:space:]]*['\"]?${key}['\"]?[[:space:]]*=[[:space:]]*\"([^\"]*)\".*/\1/p" "${file}")
        [ -n "${value}" ] && break
    done

    echo "${value}"
}

get_management_mode() {
    mode=$(
            ba-cli -l "${PROCESS_MANAGER_DM}.ManagementMode?" 2>&1 \
            | grep -v '^ERROR:' \
            | tr -d '\n'
        )

    # Fallback to prplMesh configuration DM
    [ -z "${mode}" ] && mode=$(odl_get_str_param "ManagementMode")

    echo "${mode}"
}

start_service() {
    # FIXME: 'service prplmesh stop' returns before children fully exit,
    # so any rapid stop followed by start races the new start against
    # leftover processes. Force-kill them before start.
    pkill -9 -f "^${PRPLMESH_DIR}/bin/(beerocks_(agent|controller|fronthaul|vendor_message)|ieee1905_transport)( |\$)"

    if ! pwhm_ready_poll; then
        echo "pwhm not ready - aborting prplmesh start" >&2
        exit 1
    fi

    mode="$(get_management_mode)"
    if [ -z "${mode}" ]; then
        echo "failed to get management_mode - aborting prplmesh start" >&2
        exit 1
    fi

    # This is required for solving issue which causing messages not getting to their destination.
    # For more information see: https://github.com/prplfoundation/prplMesh/pull/1029#issuecomment-608353274
    ebtables -A FORWARD -d 01:80:c2:00:00:13 -j DROP

    echo "Starting prplmesh with mode ${mode}"

    register_service "prplmesh_transport" "${PRPLMESH_DIR}/bin/ieee1905_transport"
    # If mode isn't Multi-AP-Agent then it Multi-AP-Controller
    # or Multi-AP-Controller-and-Agent so we need to register
    # controller process as well
    if [ "${mode}" != "Multi-AP-Agent" ] && [ "${mode}" != "Non-Prpl-Controller-and-Agent" ]; then
        register_service "prplmesh_controller" "${PRPLMESH_DIR}/bin/beerocks_controller"
    fi
    register_service "prplmesh_agent" "${PRPLMESH_DIR}/bin/beerocks_agent"
    register_service "prplmesh_vendor_message" "${PRPLMESH_DIR}/bin/beerocks_vendor_message"
}

stop_service() {
    deregister_service "prplmesh_vendor_message"
    deregister_service "prplmesh_agent"
    deregister_service "prplmesh_controller"
    deregister_service "prplmesh_transport"

    ebtables -D FORWARD -d 01:80:c2:00:00:13 -j DROP
}
