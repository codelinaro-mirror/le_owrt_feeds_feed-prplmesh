+static void test_local_dm_survives_bus_ctx_mutation(void** state) {
+    ttb_amx_t* ttbAmx = *state;
+    amxd_dm_t* savedDm = ttbAmx->bus_ctx->dm;
+    amxb_bus_ctx_t transientBusCtx = *ttbAmx->bus_ctx;
+    amxd_dm_t* localDm = NULL;
+
+    swl_lib_cleanup();
+    assert_true(swl_lib_initialize(&transientBusCtx));
+
+    memset(&transientBusCtx, 0, sizeof(transientBusCtx));
+
+    localDm = swl_lib_getLocalDm();
+    assert_non_null(localDm);
+    assert_ptr_equal(localDm, savedDm);
+    assert_int_equal(localDm->object.type, amxd_object_root);
+
+    swl_lib_cleanup();
+    assert_true(swl_lib_initialize(ttbAmx->bus_ctx));
+}
